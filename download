<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Zomerbar · Beheer</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --sun:#EF9F27;--sun-d:#BA7517;--sun-l:#FAEEDA;--sun-t:#412402;
  --teal:#1D9E75;--teal-l:#E1F5EE;--teal-d:#0F6E56;
  --coral:#D85A30;--coral-l:#FAECE7;--coral-d:#993C1D;
  --bg:#F7F6F2;--card:#fff;--bd:#E5E3DC;
  --tx:#1A1917;--mu:#6B6A65;--mu2:#9B9A96;
  --r:12px;--rm:8px;
}
body{font-family:'Inter',sans-serif;background:var(--bg);min-height:100vh;color:var(--tx);}
header{background:var(--sun);padding:12px 20px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:10;}
.logo{font-size:16px;font-weight:600;color:var(--sun-t);}
.logo-sub{font-size:11px;color:#633806;}
.back-link{font-size:13px;color:var(--sun-t);text-decoration:none;font-weight:500;}

.nav{display:flex;background:var(--card);border-bottom:0.5px solid var(--bd);overflow-x:auto;}
.nav-btn{flex:0 0 auto;padding:11px 16px;font-size:13px;font-weight:500;color:var(--mu);border:none;background:none;cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;}
.nav-btn.on{color:var(--sun-d);border-bottom-color:var(--sun);}
.screen{display:none;}.screen.on{display:block;}

.wrap{max-width:680px;margin:0 auto;padding:16px;}
.sec{margin-bottom:22px;}
.sec-title{font-size:11px;font-weight:600;color:var(--mu);text-transform:uppercase;letter-spacing:.05em;margin-bottom:10px;}
.card{background:var(--card);border:0.5px solid var(--bd);border-radius:var(--r);overflow:hidden;}
.row{display:flex;align-items:center;gap:10px;padding:11px 14px;border-bottom:0.5px solid var(--bd);}
.row:last-child{border-bottom:none;}
.row-label{flex:1;font-size:14px;color:var(--tx);}
.row-sub{font-size:11px;color:var(--mu);margin-top:2px;}
.inp{font-size:13px;padding:7px 10px;border:0.5px solid var(--bd);border-radius:var(--rm);background:var(--bg);color:var(--tx);width:190px;text-align:right;}
.inp:focus{outline:none;border-color:var(--sun);}
select.inp{cursor:pointer;}

.btn{padding:10px 16px;font-size:13px;font-weight:600;border:none;border-radius:var(--rm);cursor:pointer;transition:all .12s;}
.btn:active{transform:scale(.97);}
.btn-sun{background:var(--sun);color:var(--sun-t);}
.btn-teal{background:var(--teal);color:#fff;}
.btn-coral{background:var(--coral-l);color:var(--coral-d);border:0.5px solid var(--coral);}
.btn-ghost{background:var(--card);color:var(--tx);border:0.5px solid var(--bd);}
.btn-full{width:100%;padding:12px;margin-top:10px;}

/* Products */
.prod-row{display:flex;align-items:center;gap:10px;padding:10px 14px;border-bottom:0.5px solid var(--bd);}
.prod-row:last-child{border-bottom:none;}
.prod-icon{font-size:22px;width:30px;text-align:center;}
.prod-info{flex:1;}
.prod-name{font-size:14px;font-weight:500;}
.prod-meta{font-size:11px;color:var(--mu);margin-top:1px;}
.prod-price{font-size:14px;font-weight:600;color:var(--sun-d);margin-right:8px;}
.icon-btn{width:30px;height:30px;border-radius:var(--rm);border:0.5px solid var(--bd);background:var(--bg);cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;}

.add-form{background:var(--sun-l);border:0.5px solid var(--sun);border-radius:var(--r);padding:16px;margin-top:10px;display:none;}
.add-form.show{display:block;}
.add-form label{font-size:11px;font-weight:600;color:var(--mu);display:block;margin-bottom:4px;margin-top:10px;text-transform:uppercase;letter-spacing:.04em;}
.add-form label:first-child{margin-top:0;}
.add-form input,.add-form select{width:100%;font-size:13px;padding:9px 12px;border:0.5px solid var(--bd);border-radius:var(--rm);background:var(--card);color:var(--tx);}
.add-form-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.add-form-btns{display:flex;gap:8px;margin-top:14px;}
.add-form-btns .btn{flex:1;padding:11px;}

/* Stock */
.stock-n{font-size:16px;font-weight:600;min-width:36px;text-align:right;}
.stock-n.low{color:var(--coral-d);}
.stock-n.ok{color:var(--teal-d);}
.stock-n.unlimited{color:var(--mu2);}
.stock-ctrl{display:flex;align-items:center;gap:5px;margin-left:8px;}
.sbtn{width:26px;height:26px;border-radius:50%;border:0.5px solid var(--bd);background:var(--bg);cursor:pointer;font-size:14px;font-weight:600;display:flex;align-items:center;justify-content:center;}

/* SMS test */
.sms-test-row{display:flex;gap:8px;margin-top:10px;}
.sms-test-row input{flex:1;font-size:13px;padding:9px 12px;border:0.5px solid var(--bd);border-radius:var(--rm);background:var(--bg);color:var(--tx);}

/* Status pill */
.status-pill{font-size:11px;padding:3px 9px;border-radius:12px;font-weight:600;}
.pill-ok{background:var(--teal-l);color:var(--teal-d);}
.pill-err{background:var(--coral-l);color:var(--coral-d);}

.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(8px);background:#1A1917;color:#F7F6F2;font-size:13px;font-weight:500;padding:12px 22px;border-radius:24px;opacity:0;transition:all .25s;z-index:200;pointer-events:none;white-space:nowrap;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
</style>
</head>
<body>
<header>
  <div><div class="logo">⚙️ Beheer</div><div class="logo-sub">Zomerbar adminpaneel</div></div>
  <a class="back-link" href="/bar.html">← Bar-dashboard</a>
</header>

<div class="nav">
  <button class="nav-btn on" onclick="showScreen('products',this)">🍺 Producten</button>
  <button class="nav-btn" onclick="showScreen('stock',this);renderStock()">📦 Stock</button>
  <button class="nav-btn" onclick="showScreen('sumup',this)">💳 SumUp</button>
  <button class="nav-btn" onclick="showScreen('sms',this)">📱 SMS</button>
  <button class="nav-btn" onclick="showScreen('billit',this)">🧾 Billit</button>
  <button class="nav-btn" onclick="showScreen('vat',this)">% BTW</button>
  <button class="nav-btn" onclick="showScreen('security',this)">🔒 Beveiliging</button>
</div>

<!-- Producten -->
<div id="screen-products" class="screen on">
  <div class="wrap">
    <div class="sec">
      <div class="sec-title">Menu-items</div>
      <div class="card" id="prod-list"></div>
      <div class="add-form" id="add-form">
        <label>Naam</label><input id="np-name" placeholder="Rosé">
        <div class="add-form-grid">
          <div><label>Categorie</label><input id="np-cat" placeholder="Cocktails"></div>
          <div><label>Prijs (€)</label><input id="np-price" type="number" step="0.5" min="0" placeholder="4.50"></div>
        </div>
        <div class="add-form-grid">
          <div><label>Emoji</label><input id="np-icon" placeholder="🍷" maxlength="4"></div>
          <div><label>Beginstock</label><input id="np-stock" type="number" min="-1" placeholder="-1 = onbeperkt"></div>
        </div>
        <label>Type BTW</label>
        <select id="np-vat"><option value="drinks">Drank (6% BTW)</option><option value="food">Maaltijd (12% BTW)</option></select>
        <div class="add-form-btns">
          <button class="btn btn-ghost" onclick="document.getElementById('add-form').classList.remove('show')">Annuleren</button>
          <button class="btn btn-sun" onclick="saveProduct()">Opslaan</button>
        </div>
      </div>
      <button class="btn btn-sun btn-full" onclick="document.getElementById('add-form').classList.toggle('show')">+ Product toevoegen</button>
    </div>
  </div>
</div>

<!-- Stock -->
<div id="screen-stock" class="screen">
  <div class="wrap">
    <div class="sec">
      <div class="sec-title">Voorraad per product</div>
      <div class="card" id="stock-list"></div>
    </div>
  </div>
</div>

<!-- SumUp -->
<div id="screen-sumup" class="screen">
  <div class="wrap">
    <div class="sec">
      <div class="sec-title">SumUp API</div>
      <div class="card">
        <div class="row"><div><div class="row-label">API-sleutel</div><div class="row-sub">sup_sk_… via me.sumup.com/settings/api-keys</div></div><input class="inp" id="s-sumup" type="password" placeholder="sup_sk_…"></div>
        <div class="row"><div class="row-label">Merchant ID</div><input class="inp" id="s-merchant" placeholder="MXXXXXXX"></div>
      </div>
      <button class="btn btn-teal btn-full" onclick="saveSumup()">Opslaan</button>
    </div>
    <div class="sec">
      <div class="sec-title">Catalog synchroniseren</div>
      <div class="card">
        <div class="row" style="flex-direction:column;align-items:flex-start;gap:8px;">
          <div class="row-label">Importeer producten uit SumUp catalog</div>
          <div style="font-size:13px;color:var(--mu)">Bestaande producten met hetzelfde SumUp ID worden bijgewerkt. Nieuwe producten worden toegevoegd.</div>
        </div>
      </div>
      <button class="btn btn-sun btn-full" onclick="syncSumup()">🔄 Nu synchroniseren</button>
      <div id="sync-result" style="margin-top:10px;font-size:13px;color:var(--teal-d);display:none;"></div>
    </div>
  </div>
</div>

<!-- SMS -->
<div id="screen-sms" class="screen">
  <div class="wrap">
    <div class="sec">
      <div class="sec-title">Twilio SMS</div>
      <div class="card">
        <div class="row">
          <div><div class="row-label">Account SID</div><div class="row-sub">Begint met "AC…" — te vinden op console.twilio.com</div></div>
          <input class="inp" id="s-twilio-sid" type="password" placeholder="ACxxxxxxxx">
        </div>
        <div class="row">
          <div><div class="row-label">Auth Token</div><div class="row-sub">Naast Account SID op je Twilio dashboard</div></div>
          <input class="inp" id="s-twilio-token" type="password" placeholder="Auth Token">
        </div>
        <div class="row">
          <div><div class="row-label">Van-nummer</div><div class="row-sub">Twilio telefoonnummer in E.164 formaat (bv. +32...)  of een alphanumerieke afzender</div></div>
          <input class="inp" id="s-twilio-from" placeholder="+3200000000">
        </div>
      </div>
      <button class="btn btn-teal btn-full" onclick="saveSms()">Opslaan</button>
      <div style="margin-top:10px;background:var(--teal-l);border:0.5px solid var(--teal);border-radius:var(--rm);padding:12px 14px;font-size:12px;color:var(--teal-d);line-height:1.6;">
        <strong>Gratis starten:</strong> Maak een account aan op <a href="https://www.twilio.com/try-twilio" target="_blank" style="color:var(--teal-d)">twilio.com/try-twilio</a>. Je krijgt startcredits (~€12) om te testen. Voor productie koop je een Twilio-nummer (~€1/maand) of stel je een alphanumerieke afzender in.
      </div>
    </div>
    <div class="sec">
      <div class="sec-title">SMS testen</div>
      <div class="card">
        <div class="row" style="flex-direction:column;align-items:flex-start;gap:8px;">
          <div class="row-label">Stuur een test-SMS naar je eigen gsm</div>
          <div class="sms-test-row">
            <input id="sms-test-phone" type="tel" placeholder="+32 0470 00 00 00">
            <button class="btn btn-sun" onclick="testSms()">Versturen</button>
          </div>
          <div id="sms-test-result" style="font-size:13px;display:none;padding:8px 0;"></div>
        </div>
      </div>
    </div>
    <div class="sec">
      <div class="sec-title">Wanneer wordt er een SMS verstuurd?</div>
      <div class="card">
        <div class="row" style="flex-direction:column;align-items:flex-start;">
          <div style="font-size:13px;color:var(--mu);line-height:1.7;">
            Wanneer de barman een bestelling markeert als <strong>"Klaar ✅"</strong> op het bar-dashboard, ontvangt de klant automatisch een SMS op het nummer dat hij invulde bij de bestelling:<br><br>
            <div style="background:var(--bg);border-radius:var(--rm);padding:10px 12px;font-style:italic;color:var(--tx);border:0.5px solid var(--bd);">
              "Zomerbar: Bestelling #12 is klaar! Haal op aan de bar. Smakelijk! ☀️"
            </div><br>
            Vult de klant geen gsm-nummer in, dan wordt er geen SMS verstuurd maar werkt alles verder normaal.
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Billit -->
<div id="screen-billit" class="screen">
  <div class="wrap">
    <div class="sec">
      <div class="sec-title">Billit Facturatie</div>
      <div class="card">
        <div class="row"><div><div class="row-label">API-sleutel</div><div class="row-sub">Te vinden in je Billit-account</div></div><input class="inp" id="s-billit-key" type="password" placeholder="apiKey…"></div>
        <div class="row"><div class="row-label">Omgeving</div><select class="inp" id="s-billit-env"><option value="sandbox">Sandbox (testen)</option><option value="production">Productie</option></select></div>
        <div class="row"><div class="row-label">Naam bar</div><input class="inp" id="s-bar-name" placeholder="Zomerbar"></div>
        <div class="row"><div><div class="row-label">BTW-nummer bar</div><div class="row-sub">BE + 10 cijfers</div></div><input class="inp" id="s-bar-vat" placeholder="BE0000000000"></div>
      </div>
      <button class="btn btn-teal btn-full" onclick="saveBillit()">Opslaan</button>
    </div>
  </div>
</div>

<!-- BTW -->
<div id="screen-vat" class="screen">
  <div class="wrap">
    <div class="sec">
      <div class="sec-title">BTW-tarieven</div>
      <div class="card">
        <div class="row"><div><div class="row-label">Dranken</div><div class="row-sub">Standaard 6% in België</div></div><select class="inp" id="s-vat-drinks"><option value="21">21%</option><option value="12">12%</option><option value="6" selected>6%</option></select></div>
        <div class="row"><div><div class="row-label">Maaltijden</div><div class="row-sub">Standaard 12% in België</div></div><select class="inp" id="s-vat-food"><option value="21">21%</option><option value="12" selected>12%</option><option value="6">6%</option></select></div>
      </div>
      <button class="btn btn-teal btn-full" onclick="saveVat()">Opslaan</button>
    </div>
    <div class="sec">
      <div class="sec-title">Meer info</div>
      <div class="card">
        <div class="row" style="flex-direction:column;align-items:flex-start;gap:4px;">
          <div style="font-size:13px;color:var(--mu);line-height:1.7;">
            Bij een popup-zomerbar gelden in België doorgaans:<br>
            • <strong>6%</strong> voor niet-alcoholische dranken en bieren<br>
            • <strong>21%</strong> voor alcoholische dranken (bij afhaal)<br>
            • <strong>12%</strong> voor maaltijden ter plaatse<br>
            Raadpleeg je boekhouder voor je specifieke situatie.
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Beveiliging -->
<div id="screen-security" class="screen">
  <div class="wrap">
    <div class="sec">
      <div class="sec-title">Admin-wachtwoord</div>
      <div class="card">
        <div class="row"><div class="row-label">Huidig wachtwoord</div><input class="inp" id="s-cur-pw" type="password" placeholder="••••••••"></div>
        <div class="row"><div class="row-label">Nieuw wachtwoord</div><input class="inp" id="s-new-pw" type="password" placeholder="Minstens 4 tekens"></div>
        <div class="row"><div class="row-label">Bevestig nieuw</div><input class="inp" id="s-new-pw2" type="password" placeholder="Herhaal"></div>
      </div>
      <button class="btn btn-teal btn-full" onclick="changePassword()">Wachtwoord wijzigen</button>
    </div>
    <div class="sec">
      <div class="sec-title">Sessie</div>
      <div class="card">
        <div class="row">
          <div class="row-label">Actieve sessie</div>
          <span class="status-pill pill-ok">Ingelogd ✓</span>
        </div>
      </div>
      <button class="btn btn-coral btn-full" onclick="logout()">🚪 Uitloggen</button>
    </div>
    <div class="sec">
      <div class="sec-title">Tip</div>
      <div class="card">
        <div class="row" style="flex-direction:column;align-items:flex-start;">
          <div style="font-size:13px;color:var(--mu);line-height:1.7;">
            Zet de VPS achter <strong>HTTPS</strong> zodat het wachtwoord versleuteld verstuurd wordt. Dit kan via Nginx Proxy Manager (gratis) met een Let's Encrypt certificaat.
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script src="/api.js"></script>
<script>
// ── Auth guard ──
(async () => {
  if (!API.getToken()) { window.location.href = '/login.html?next=/beheer.html'; return; }
  try { const c = await API.auth.check(); if (!c.valid) window.location.href = '/login.html?next=/beheer.html'; }
  catch(_) { window.location.href = '/login.html?next=/beheer.html'; }
})();
</script>
<script>
let products = [], settings = {};

function showScreen(name, btn) {
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('on'));
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('on'));
  document.getElementById('screen-'+name).classList.add('on');
  if(btn)btn.classList.add('on');
}

async function init() {
  [products, settings] = await Promise.all([API.products.list(), API.settings.get()]);
  renderProducts();
  loadSettingsToForm();
}

// ── Products ─────────────────────────────────────────────────────
function renderProducts() {
  const grouped = {};
  products.forEach(p => { if(!grouped[p.category])grouped[p.category]=[]; grouped[p.category].push(p); });
  let html = '';
  Object.entries(grouped).forEach(([cat, prods]) => {
    html += `<div style="padding:8px 14px;font-size:11px;font-weight:600;color:var(--mu);text-transform:uppercase;letter-spacing:.05em;border-bottom:0.5px solid var(--bd);background:var(--bg)">${cat}</div>`;
    prods.forEach(p => {
      const stockLbl = p.stock<0?'∞':p.stock<=p.low_stock?`<span style="color:var(--coral-d)">${p.stock} ⚠</span>`:p.stock;
      html += `<div class="prod-row">
        <span class="prod-icon">${p.icon}</span>
        <div class="prod-info"><div class="prod-name">${p.name}</div><div class="prod-meta">Stock: ${stockLbl} · ${p.vat_type==='food'?'12%':'6%'} BTW</div></div>
        <span class="prod-price">€ ${p.price.toFixed(2).replace('.',',')}</span>
        <button class="icon-btn" onclick="deleteProduct(${p.id})" title="Verwijderen">🗑</button>
      </div>`;
    });
  });
  document.getElementById('prod-list').innerHTML = html || '<div style="padding:20px;font-size:13px;color:var(--mu)">Geen producten</div>';
}

async function saveProduct() {
  const name = document.getElementById('np-name').value.trim();
  const category = document.getElementById('np-cat').value.trim();
  const price = parseFloat(document.getElementById('np-price').value);
  const icon = document.getElementById('np-icon').value.trim() || '🍺';
  const stock = parseInt(document.getElementById('np-stock').value ?? -1);
  const vat_type = document.getElementById('np-vat').value;
  if (!name || !category || isNaN(price)) { toast('Vul naam, categorie en prijs in'); return; }
  try {
    const p = await API.products.add({ name, category, price, icon, stock: isNaN(stock)?-1:stock, vat_type });
    products.push(p);
    renderProducts();
    document.getElementById('add-form').classList.remove('show');
    ['np-name','np-cat','np-price','np-icon','np-stock'].forEach(id => document.getElementById(id).value='');
    toast('✅ Product toegevoegd');
  } catch(e) { toast('Fout: '+e.message); }
}

async function deleteProduct(id) {
  if (!confirm('Product verwijderen uit het menu?')) return;
  await API.products.remove(id);
  products = products.filter(p => p.id !== id);
  renderProducts();
  toast('Verwijderd');
}

// ── Stock ────────────────────────────────────────────────────────
function renderStock() {
  document.getElementById('stock-list').innerHTML = products.map(p => {
    const ul = p.stock < 0;
    const low = !ul && p.stock <= p.low_stock;
    const cls = ul ? 'unlimited' : low ? 'low' : 'ok';
    return `<div class="prod-row">
      <span class="prod-icon">${p.icon}</span>
      <div class="prod-info"><div class="prod-name">${p.name}</div><div class="prod-meta">${p.category}</div></div>
      <span class="stock-n ${cls}">${ul ? '∞' : p.stock}</span>
      <div class="stock-ctrl">
        <button class="sbtn" onclick="adjStock(${p.id},-1)">−</button>
        <button class="sbtn" onclick="adjStock(${p.id},1)">+</button>
        <button class="sbtn" onclick="setStockManual(${p.id})">✏️</button>
      </div>
    </div>`;
  }).join('');
}

async function adjStock(id, delta) {
  const p = products.find(x=>x.id===id); if(!p||p.stock<0) return;
  const n = Math.max(0, p.stock+delta);
  await API.products.setStock(id, n); p.stock = n; renderStock();
}

async function setStockManual(id) {
  const p = products.find(x=>x.id===id); if(!p) return;
  const val = prompt('Nieuwe stock (of -1 voor onbeperkt):', p.stock<0?'-1':p.stock);
  if (val===null) return;
  const n = parseInt(val);
  if (isNaN(n)) return;
  await API.products.setStock(id, n); p.stock = n; renderStock();
}

// ── Settings helpers ─────────────────────────────────────────────
function loadSettingsToForm() {
  const s = settings;
  if(s.sumupKey)    document.getElementById('s-sumup').value=s.sumupKey;
  if(s.merchant)    document.getElementById('s-merchant').value=s.merchant;
  if(s.twilioAccountSid) document.getElementById('s-twilio-sid').value=s.twilioAccountSid;
  if(s.twilioAuthToken)  document.getElementById('s-twilio-token').value=s.twilioAuthToken;
  if(s.twilioFrom)       document.getElementById('s-twilio-from').value=s.twilioFrom;
  if(s.billitApiKey) document.getElementById('s-billit-key').value=s.billitApiKey;
  if(s.billitEnv)    document.getElementById('s-billit-env').value=s.billitEnv;
  if(s.barName)      document.getElementById('s-bar-name').value=s.barName;
  if(s.barVat)       document.getElementById('s-bar-vat').value=s.barVat;
  if(s.vatDrinks)    document.getElementById('s-vat-drinks').value=s.vatDrinks;
  if(s.vatFood)      document.getElementById('s-vat-food').value=s.vatFood;
}

async function saveSumup() {
  await API.settings.save({ sumupKey: document.getElementById('s-sumup').value, merchant: document.getElementById('s-merchant').value });
  toast('✅ SumUp instellingen opgeslagen');
}

async function syncSumup() {
  const el = document.getElementById('sync-result');
  el.style.display='none';
  toast('Synchroniseren met SumUp catalog…');
  try {
    const r = await API.products.syncSumup();
    products = r.products || products;
    renderProducts();
    el.style.display='block';
    el.textContent = `✅ ${r.synced} producten gesynchroniseerd`;
    toast('✅ Sync klaar');
  } catch(e) {
    el.style.display='block'; el.style.color='var(--coral-d)';
    el.textContent = '❌ ' + e.message;
    toast('SumUp fout: '+e.message);
  }
}

async function saveSms() {
  await API.settings.save({
    twilioAccountSid: document.getElementById('s-twilio-sid').value,
    twilioAuthToken:  document.getElementById('s-twilio-token').value,
    twilioFrom:       document.getElementById('s-twilio-from').value,
  });
  toast('✅ Twilio instellingen opgeslagen');
}

async function testSms() {
  const phone = document.getElementById('sms-test-phone').value.trim();
  const el = document.getElementById('sms-test-result');
  if (!phone) { toast('Vul een gsm-nummer in'); return; }
  el.style.display='none';
  toast('SMS versturen…');
  try {
    await fetch('/api/sms/test', { method:'POST', headers:{'Content-Type':'application/json','x-admin-token':API.getToken()}, body:JSON.stringify({phone}) });
    el.style.display='block'; el.style.color='var(--teal-d)';
    el.textContent = '✅ Test-SMS verstuurd naar '+phone;
    toast('✅ SMS verstuurd');
  } catch(e) { toast('SMS fout: '+e.message); }
}

async function saveBillit() {
  await API.settings.save({ billitApiKey: document.getElementById('s-billit-key').value, billitEnv: document.getElementById('s-billit-env').value, barName: document.getElementById('s-bar-name').value, barVat: document.getElementById('s-bar-vat').value });
  toast('✅ Billit instellingen opgeslagen');
}

async function saveVat() {
  await API.settings.save({ vatDrinks: document.getElementById('s-vat-drinks').value, vatFood: document.getElementById('s-vat-food').value });
  toast('✅ BTW-tarieven opgeslagen');
}

async function changePassword() {
  const cur = document.getElementById('s-cur-pw').value;
  const nw = document.getElementById('s-new-pw').value;
  const nw2 = document.getElementById('s-new-pw2').value;
  if (!cur || !nw) { toast('Vul alle velden in'); return; }
  if (nw !== nw2) { toast('Wachtwoorden komen niet overeen'); return; }
  if (nw.length < 4) { toast('Minstens 4 tekens'); return; }
  // Verify current password by trying to login
  try {
    await API.auth.changePassword(nw);
    document.getElementById('s-cur-pw').value='';
    document.getElementById('s-new-pw').value='';
    document.getElementById('s-new-pw2').value='';
    toast('✅ Wachtwoord gewijzigd');
  } catch(e) { toast('Fout: '+e.message); }
}

async function logout() {
  if (!confirm('Uitloggen?')) return;
  try { await API.auth.logout(); } catch(_) {}
  API.setToken(null);
  window.location.href = '/login.html';
}

function toast(msg) {
  const t=document.getElementById('toast');
  t.textContent=msg; t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),3000);
}

init();
</script>
</body>
</html>
